class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int leftCount=0;
        int rightCount=0;
        int both=0;
        for(int i=0; i<moves.length(); i++){
          if(moves.charAt(i)=='L') leftCount++;
          else if(moves.charAt(i)=='R') rightCount++;
          else{
            both++;
          }
        }
        return Math.abs(leftCount-rightCount)+both;    
    }
}
