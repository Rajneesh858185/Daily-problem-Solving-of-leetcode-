class Solution {
    public int reverse(int n){
        int reverse=0;
        while(n>0){
           reverse*=10;
           int lastDigit=n%10;
           reverse+=lastDigit;
           n=n/10;
        }
        return reverse;
    }
    public int mirrorDistance(int n) {
        return Math.abs(n-reverse(n));
    }
}
